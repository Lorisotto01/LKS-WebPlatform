# Credenziali pubbliche Supabase — sicure da spedire al browser.
# Usa la "publishable key" (sb_publishable_...) dei progetti recenti,
# oppure la vecchia "anon key" sui progetti legacy. Sono equivalenti.
# La chiave secret/service_role NON va mai qui (solo nel Tool CLI).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx
# In alternativa (legacy):
# VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Base URL per i link di verifica email. In sviluppo metti l'IP LAN della macchina
# (es. http://192.168.1.50:5173) cosi il link funziona anche aprendolo dal telefono.
# In produzione: il dominio Netlify. Vuoto = usa l'origine corrente del browser.
# Ricorda di aggiungerlo agli allowed Redirect URLs in Supabase.
VITE_PUBLIC_SITE_URL=http://192.168.1.XX:5173
